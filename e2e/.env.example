# E2E test environment — copy to .env.local in repo root, or set in CI.
# These vars MUST point at a dedicated TEST Supabase project (local CLI or staging).
# NEVER reuse production credentials.

# Base URL for Playwright tests. Default is the local Next.js dev server.
BASE_URL=http://localhost:3000

# Test Supabase project (use `supabase start` for a local instance).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-me-with-test-project-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me-with-test-project-anon-key

# Optional: set to 1 to skip the auto-managed `npm run dev` web server
# (useful when targeting a deployed BASE_URL such as a Vercel preview).
# SKIP_WEB_SERVER=1
