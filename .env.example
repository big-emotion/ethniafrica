# ──────────────────────────────────────────────────────────────────────────────
# Sentry — EU data residency (GDPR NFR34 / AR28 / AR38)
# ──────────────────────────────────────────────────────────────────────────────
# Both DSN values MUST use the EU ingestion hostname:
#   https://o<org-id>.ingest.de.sentry.io/<project-id>
#                           ^^
#                     "de" subdomain = EU region
#
# Using a US DSN (ingest.sentry.io) will cause a startup error in production
# and a console warning in development (see src/lib/sentry/pii-scrubber.ts).
#
# Server-side / Edge (not exposed to browser):
SENTRY_DSN=https://o<org-id>.ingest.de.sentry.io/<project-id>

# Client-side (prefixed NEXT_PUBLIC_*, included in browser bundle):
NEXT_PUBLIC_SENTRY_DSN=https://o<org-id>.ingest.de.sentry.io/<project-id>

# Required for build-step source-map upload (set in CI/CD secrets, never commit):
SENTRY_AUTH_TOKEN=
