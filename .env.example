# ──────────────────────────────────────────────────────────────────────────────
# EthniAfrica — canonical example env file
# Copy to `.env.local` for local development. Every `process.env.X` reference
# in `src/` and `scripts/` is documented here.
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# Site identity (required for SEO, canonical URLs, OG tags)
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ethniafrica.com
NEXT_PUBLIC_CANONICAL_DOMAIN=ethniafrica.com
NEXT_PUBLIC_WEBSITE_NAME="ETHNIAFRICA"
NEXT_PUBLIC_PRODUCT_NAME="EthniAfrica"
NEXT_PUBLIC_SITE_LOCALE=fr_FR
NEXT_PUBLIC_OG_TITLE="EthniAfrica — données ouvertes sur les peuples d'Afrique"
NEXT_PUBLIC_OG_DESCRIPTION=""
NEXT_PUBLIC_ATTRIBUTION_STRING="BIG EMOTION"
NEXT_PUBLIC_BIG_EMOTION_NAME="BIG EMOTION"
NEXT_PUBLIC_GITHUB_URL=https://github.com/big-emotion/ethniafrica

# ──────────────────────────────────────────────────────────────────────────────
# Supabase (required)
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY. Never expose in the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=
USE_SUPABASE=true

# ──────────────────────────────────────────────────────────────────────────────
# Cache revalidation (required)
# ──────────────────────────────────────────────────────────────────────────────
REVALIDATE_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# CORS (optional — defaults to NEXT_PUBLIC_SITE_URL)
# ──────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN=

# ──────────────────────────────────────────────────────────────────────────────
# Rate limiting — Upstash Redis (required in production for /api/v2/*)
# ──────────────────────────────────────────────────────────────────────────────
# When both vars are missing, rate limiting fails OPEN in non-production
# (see src/lib/api/rate-limit.ts).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated lists of API key prefixes granted the matching tier.
RATE_LIMIT_PARTNER_KEYS=
RATE_LIMIT_ADMIN_KEYS=

# Per-tier requests-per-minute quotas. Defaults preserve current behavior.
RATE_LIMIT_IP_RPM=60
RATE_LIMIT_PUBLIC_RPM=600
RATE_LIMIT_PARTNER_RPM=6000
# Window duration accepted by @upstash/ratelimit (e.g. "1 m", "30 s").
RATE_LIMIT_WINDOW=1 m

# ──────────────────────────────────────────────────────────────────────────────
# Sentry — EU data residency (GDPR NFR34 / AR28 / AR38)
# ──────────────────────────────────────────────────────────────────────────────
# Both DSN values MUST use the EU ingestion hostname:
#   https://o<org-id>.ingest.de.sentry.io/<project-id>
# Using a US DSN (ingest.sentry.io) throws at startup in production and
# warns in development (see src/lib/sentry/pii-scrubber.ts).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Required for build-step source-map upload (set in CI/CD, never commit).
SENTRY_AUTH_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Plausible Analytics — cookie-less, EU-hosted (GDPR AR26 / AR37 / NFR42)
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional — override script host for self-hosted Plausible.
NEXT_PUBLIC_PLAUSIBLE_CUSTOM_DOMAIN=

# ──────────────────────────────────────────────────────────────────────────────
# Admin (optional)
# ──────────────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=

# ──────────────────────────────────────────────────────────────────────────────
# CI / contract tests (optional — only set in CI)
# ──────────────────────────────────────────────────────────────────────────────
TEST_SUPABASE_URL=
TEST_SUPABASE_ANON_KEY=
TEST_SUPABASE_SERVICE_KEY=
TEST_JWT_ADMIN=
TEST_JWT_MODERATOR=
TEST_JWT_CONTRIBUTOR=
TEST_JWT_READER=
# Allow contract suite to record breaking changes intentionally.
API_BREAKING=
# Enable HEAD probes on source URLs in data-integrity job.
CHECK_SOURCE_URLS=
